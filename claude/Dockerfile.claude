#ddev-generated
# Image outil pour Claude Code + RTK (Rust Token Killer).
# GSD (git ship done) n'est PAS installe dans l'image : il s'installe par projet
# via `npx @opengsd/gsd-core` (manuellement, cf. README) ; on garde Node/npx pour ca.
#
# Gestion du user : on cree dans l'image un utilisateur dont l'UID/GID correspond
# a celui de l'hote, injecte AU BUILD via build args (DDEV expose DDEV_UID/DDEV_GID,
# relayes par le compose). On desamorce la collision d'UID/GID : l'image de base a
# deja un user en 1000 (l'utilisateur `node`), donc si l'UID/GID cible est occupe
# par quelqu'un d'autre, on le supprime avant de creer le notre. Resultat : un vrai
# utilisateur nomme, avec home dans /etc/passwd et shell -> session interactive propre.

FROM node:24-bookworm-slim

ARG USERNAME=claude
ARG USER_UID=1000
ARG USER_GID=1000

ENV DEBIAN_FRONTEND=noninteractive
ENV USERNAME=${USERNAME}
ENV USER_HOME=/home/${USERNAME}

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
       git \
       curl \
       ca-certificates \
       ripgrep \
       less \
       sudo \
       jq \
  && rm -rf /var/lib/apt/lists/*

# RTK (Rust Token Killer) -- binaire pre-compile via le script d'install officiel.
# IMPORTANT : rtk-ai/rtk explicitement. NE PAS faire `cargo install rtk`
# (collision de nom avec "Rust Type Kit" sur crates.io). Installe en global (root)
# AVANT le switch d'utilisateur, donc dispo sur le PATH pour tous.
RUN curl -fsSL https://raw.githubusercontent.com/rtk-ai/rtk/refs/heads/master/install.sh \
      | sh \
  && (command -v rtk >/dev/null 2>&1 \
      || cp "$HOME/.local/bin/rtk" /usr/local/bin/rtk 2>/dev/null \
      || true) \
  && rtk --version

# Cree l'utilisateur avec l'UID/GID de l'hote, en desamorcant toute collision.
RUN existing_user=$(getent passwd ${USER_UID} | cut -d: -f1) \
  && existing_group=$(getent group ${USER_GID} | cut -d: -f1) \
  && if [ -n "$existing_user" ] && [ "$existing_user" != "${USERNAME}" ]; then \
       userdel -r "$existing_user" 2>/dev/null || true; \
     fi \
  && if [ -n "$existing_group" ] && [ "$existing_group" != "${USERNAME}" ]; then \
       groupdel "$existing_group" 2>/dev/null || true; \
     fi \
  && groupadd --gid ${USER_GID} ${USERNAME} 2>/dev/null || true \
  && useradd --uid ${USER_UID} --gid ${USER_GID} -m -s /bin/bash ${USERNAME} 2>/dev/null || true \
  && echo "${USERNAME} ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/${USERNAME} \
  && chmod 0440 /etc/sudoers.d/${USERNAME} \
  && passwd -d ${USERNAME} 2>/dev/null || true

# Repertoires utiles, possedes par l'utilisateur.
RUN mkdir -p ${USER_HOME}/.claude ${USER_HOME}/.local/bin ${USER_HOME}/.npm-global /var/www/html \
  && chown -R ${USER_UID}:${USER_GID} ${USER_HOME} /var/www/html

USER ${USERNAME}
WORKDIR ${USER_HOME}

# PATH : ~/.local/bin (ou atterrit l'installeur natif de Claude Code) puis npm-global.
ENV HOME=${USER_HOME}
ENV CLAUDE_CONFIG_DIR=${USER_HOME}/.claude
ENV NPM_CONFIG_PREFIX=${USER_HOME}/.npm-global
ENV PATH="${USER_HOME}/.local/bin:${USER_HOME}/.npm-global/bin:${PATH}"

# Claude Code via l'installeur natif officiel (recommande par Anthropic),
# plutot que `npm install -g`. Atterrit dans ~/.local/bin.
RUN curl -fsSL https://claude.ai/install.sh | bash \
  && claude --version

# Le code projet est monte ici par DDEV (declare dans le compose).
WORKDIR /var/www/html

# Conteneur outil : reste vivant, on exec dedans a la demande.
CMD ["tail", "-f", "/dev/null"]