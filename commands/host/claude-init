#!/usr/bin/env bash

## Description: Initialise Claude dans le conteneur (auth OAuth, hook RTK, install GSD du projet)
## Usage: claude-init
## Example: "ddev claude-init"
## CanRunGlobally: false

#ddev-generated

set -eu

CONTAINER="ddev-${DDEV_SITENAME}-claude"

if ! docker ps --format '{{.Names}}' | grep -q "^${CONTAINER}$"; then
  echo "Le service 'claude' n'est pas démarré. Lance: ddev restart" >&2
  exit 1
fi

echo "==> 1/3 Authentification Claude Code (OAuth)"
echo "    Une URL va s'afficher : ouvre-la dans TON navigateur, authentifie-toi,"
echo "    puis recolle le code ici. (Abonnement Claude.ai/Pro/Max)"
echo ""
docker exec -it "$CONTAINER" claude /login

echo ""
echo "==> 2/3 Câblage du hook RTK dans Claude Code (rtk init -g)"
# -g écrit le hook dans la config globale du conteneur (~/.claude), donc persistée
# dans le volume. Idempotent : ré-exécuter ne casse rien.
docker exec -it "$CONTAINER" rtk init -g || {
  echo "⚠️  rtk init a échoué (non bloquant). Tu peux relancer: ddev claude-init" >&2
}

echo ""
echo "==> 3/3 Installation de GSD (git ship done) DANS le projet"
echo "    L'installateur va te demander le runtime (choisis Claude Code) et"
echo "    'local' pour une install par projet (versionnée dans le repo)."
# Exécuté avec le cwd sur le repo monté pour que GSD écrive dans le projet.
docker exec -it -w /var/www/html "$CONTAINER" npx @opengsd/gsd-core@latest || {
  echo "⚠️  Install GSD interrompue (non bloquant). Relance: ddev claude-init" >&2
}

echo ""
echo "✅ Initialisation terminée. Tu peux maintenant lancer:  ddev claude"
